reset

# Inlet.
create surface rectangle width 0.2 height 0.2 
move Volume 1 x -0.1 y +0.7 include_merged 

# Outlet.
create surface rectangle width 0.2 height 0.2 
move Volume 2 x +0.7 y -0.1 include_merged

# Domain.
create vertex 0.0 1.0
create vertex 1.0 1.0 
create vertex 1.0 0.0 
create vertex 0.0 0.0
create curve vertex  1  9
create curve vertex  9 10
create curve vertex 10 11
create curve vertex 11  5
create curve vertex  6 12
create curve vertex 12  4
create surface curve 9 10 11 12 5 13 14 4  

# Mesh.
merge all
surface all size 0.1
mesh surface all

# Blocks and sidesets.
block 1 add surface 1 3 2 
block 1 element type QUAD

sideset 1 add curve 2  
sideset 2 add curve 7  
sideset 3 add curve 1 9 10 11 12 8 6 13 14 3  

# Export.
set exodus netcdf4 off
set large exodus file on
export mesh "pipebend_2d.gen"  overwrite 
